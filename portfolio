<!-- DRONE -->
<div id="drone">
  <div class="section">
    <div class="two-col">
      <div class="drone-visual reveal" style="padding:0; overflow:hidden; border:1px solid var(--border);">
        <img src="data:image/jpeg;base64," alt="Drohnenaufnahme" style="width:100%; height:100%; object-fit:cover; display:block; transition: transform 0.5s ease;">
      </div>
      <div class="reveal d1">
        <p class="label">Luftaufnahmen</p>
        <h2 class="heading">Fotografie aus<br>der <em>Vogelperspektive</em></h2>
        <div class="drone-text">
          <p>Als lizenzierter Drohnenpilot A1/A3 erweitere ich meine kreative Arbeit um die Dimension der Luft. Drohnenaufnahmen für Imagefilme, Social-Media-Content und Werbung.</p>
