<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Maksim Cédric Voss — Mediendesigner</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #c0392b;
    --red-light: #e74c3c;
    --red-muted: rgba(192,57,43,0.06);
    --black: #0a0a0a;
    --gray-mid: #6e6e73;
    --gray-light: #f5f5f7;
    --white: #ffffff;
    --border: rgba(0,0,0,0.08);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--white);
    color: var(--black);
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: 52px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 3rem;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400; letter-spacing: 0.1em;
    color: var(--black); text-decoration: none;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: 0.78rem; font-weight: 400; color: var(--gray-mid);
    text-decoration: none; letter-spacing: 0.03em; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--black); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; text-align: center;
    padding: 8rem 2rem 6rem; position: relative; overflow: hidden;
  }
  .hero-eyebrow {
    font-size: 0.75rem; font-weight: 400; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--red); margin-bottom: 2rem;
    opacity: 0; animation: fadeUp 0.7s 0.3s ease forwards;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 11vw, 9.5rem);
    font-weight: 300; line-height: 0.92; letter-spacing: -0.02em;
    color: var(--black); opacity: 0; animation: fadeUp 0.9s 0.5s ease forwards;
  }
  .hero-title em { font-style: italic; color: var(--red); }
  .hero-sub {
    max-width: 480px; margin: 2.5rem auto 0;
    font-size: 1.05rem; font-weight: 300; color: var(--gray-mid); line-height: 1.7;
    opacity: 0; animation: fadeUp 0.9s 0.7s ease forwards;
  }
  .hero-actions {
    display: flex; gap: 1rem; justify-content: center; margin-top: 3rem;
    opacity: 0; animation: fadeUp 0.9s 0.9s ease forwards;
  }
  .btn-primary {
    display: inline-block; padding: 0.75rem 1.8rem; background: var(--red);
    color: var(--white); border-radius: 980px; font-size: 0.82rem; font-weight: 400;
    letter-spacing: 0.02em; text-decoration: none; transition: background 0.2s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--red-light); transform: scale(1.02); }
  .btn-secondary {
    display: inline-block; padding: 0.75rem 1.8rem; background: transparent;
    color: var(--red); border: 1px solid rgba(192,57,43,0.3); border-radius: 980px;
    font-size: 0.82rem; font-weight: 400; text-decoration: none;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .btn-secondary:hover { border-color: var(--red); background: var(--red-muted); transform: scale(1.02); }
  .hero-divider { position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: var(--border); }

  /* LAYOUT */
  .section { padding: 7rem 3rem; max-width: 1080px; margin: 0 auto; }
  .bg-gray { background: var(--gray-light); }
  .label {
    font-size: 0.72rem; font-weight: 500; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--red); margin-bottom: 1rem;
  }
  .heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 300;
    line-height: 1.08; letter-spacing: -0.01em; color: var(--black); margin-bottom: 3.5rem;
  }
  .heading em { font-style: italic; color: var(--red); }

  /* ABOUT */
  .two-col { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 6rem; align-items: start; }
  .about-text p { font-size: 1rem; color: var(--gray-mid); line-height: 1.85; margin-bottom: 1.1rem; }
  .about-text strong { color: var(--black); font-weight: 400; }
  .about-portrait {
    width: 100%; margin-bottom: 1.5rem;
    overflow: hidden; border: 1px solid var(--border);
  }
  .about-portrait img {
    width: 100%; height: 280px; object-fit: cover; object-position: top;
    display: block; filter: grayscale(20%);
    transition: filter 0.4s;
  }
  .about-portrait:hover img { filter: grayscale(0%); }
  .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .stat { background: var(--white); padding: 2rem 1.5rem; transition: background 0.2s; }
  .stat:hover { background: var(--red-muted); }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; font-weight: 300; color: var(--red); line-height: 1; }
  .stat-label { font-size: 0.75rem; color: var(--gray-mid); margin-top: 0.4rem; line-height: 1.4; }

  /* PROJECTS */
  .projects-list { display: flex; flex-direction: column; gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .project-row {
    display: grid; grid-template-columns: 80px 1fr auto;
    align-items: center; gap: 2rem; padding: 1.5rem 2rem;
    background: var(--white); transition: background 0.2s;
  }
  .p-thumb {
    width: 80px; height: 54px;
    overflow: hidden; border-radius: 4px;
    background: var(--gray-light); flex-shrink: 0;
  }
  .p-thumb img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.4s ease;
  }
  .project-row:hover .p-thumb img { transform: scale(1.06); }
  .project-row:hover { background: var(--gray-light); }
  .project-row:hover .p-arrow { transform: translateX(4px); color: var(--red); }

  .p-tag { font-size: 0.68rem; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 0.3rem; }
  .p-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 400; color: var(--black); line-height: 1.2; }
  .p-desc { font-size: 0.82rem; color: var(--gray-mid); margin-top: 0.3rem; line-height: 1.5; }
  .p-arrow { font-size: 1.1rem; color: var(--gray-mid); transition: transform 0.2s, color 0.2s; }

  /* SKILLS */
  .skills-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .skill-item { background: var(--white); padding: 2.5rem 2rem; transition: background 0.2s; }
  .skill-item:hover { background: var(--red-muted); }
  .skill-name { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 400; color: var(--black); margin-bottom: 1rem; }
  .tools { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tool { font-size: 0.68rem; padding: 0.22rem 0.7rem; border: 1px solid var(--border); color: var(--gray-mid); border-radius: 100px; }

  /* DRONE */
  .drone-visual {
    aspect-ratio: 1; background: var(--gray-light); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;
  }
  .drone-glow {
    position: absolute; width: 220px; height: 220px; border-radius: 50%;
    background: radial-gradient(circle, rgba(192,57,43,0.1), transparent 70%);
    animation: breathe 4s ease-in-out infinite;
  }
  .drone-icon { font-size: 5rem; position: relative; z-index: 1; animation: floatSlow 5s ease-in-out infinite; }
  .drone-text p { font-size: 1rem; color: var(--gray-mid); line-height: 1.8; margin-bottom: 1rem; }
  .badge {
    display: inline-flex; align-items: center; gap: 1rem; margin-top: 1.5rem;
    padding: 1.2rem 1.5rem; border: 1px solid var(--border); background: var(--white);
  }
  .badge-num { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: var(--red); }
  .badge-text { font-size: 0.8rem; color: var(--gray-mid); line-height: 1.5; }
  .badge-text strong { color: var(--black); font-weight: 400; display: block; }

  /* CONTACT */
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; }
  .contact-intro p { font-size: 1rem; color: var(--gray-mid); line-height: 1.8; }
  .cli {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.5rem 0; border-bottom: 1px solid var(--border);
    text-decoration: none; color: var(--black); transition: color 0.2s;
  }
  .cli:hover { color: var(--red); }
  .cli:hover .cli-arrow { transform: translateX(4px); }
  .cli-icon { font-size: 1rem; color: var(--red); width: 20px; }
  .cli-text { flex: 1; font-size: 0.95rem; }
  .cli-arrow { font-size: 0.9rem; color: var(--gray-mid); transition: transform 0.2s; }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  footer p { font-size: 0.75rem; color: var(--gray-mid); }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes floatSlow {
    0%,100% { transform: translateY(0); }
    50%     { transform: translateY(-12px); }
  }
  @keyframes breathe {
    0%,100% { transform: scale(1); opacity: 0.5; }
    50%     { transform: scale(1.4); opacity: 1; }
  }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  .d1 { transition-delay: 0.1s; }
  .d2 { transition-delay: 0.2s; }
  .d3 { transition-delay: 0.3s; }

  /* HAMBURGER */
  .hamburger {
    display: none;
    flex-direction: column; justify-content: center; gap: 5px;
    width: 32px; height: 32px; cursor: pointer; background: none; border: none; padding: 4px;
  }
  .hamburger span {
    display: block; height: 1.5px; background: var(--black);
    transition: transform 0.3s, opacity 0.3s, width 0.3s;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* MOBILE MENU OVERLAY */
  .mobile-menu {
    display: none;
    position: fixed; inset: 0; z-index: 99;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(20px);
    flex-direction: column; align-items: center; justify-content: center;
    gap: 2.5rem;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-menu.open { opacity: 1; pointer-events: all; }
  .mobile-menu a {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem; font-weight: 300;
    color: var(--black); text-decoration: none; letter-spacing: 0.05em;
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: var(--red); }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    nav { padding: 0 1.5rem; }
    .nav-links { display: none; }
    .hamburger { display: flex; }

    .section { padding: 4rem 1.5rem; }
    .bg-gray .section { padding: 4rem 1.5rem; }

    /* hero */
    .hero { padding: 7rem 1.5rem 5rem; }
    .hero-title { font-size: clamp(3.2rem, 16vw, 5rem); }
    .hero-sub { font-size: 0.95rem; }
    .hero-actions { flex-direction: column; align-items: center; gap: 0.8rem; }
    .btn-primary, .btn-secondary { width: 100%; max-width: 280px; text-align: center; }

    /* about */
    .two-col { grid-template-columns: 1fr; gap: 2.5rem; }
    .stats { grid-template-columns: 1fr 1fr; }
    .stat { padding: 1.5rem 1.2rem; }
    .stat-num { font-size: 2.2rem; }

    /* projects */
    .heading { margin-bottom: 2rem; }
    .project-row { grid-template-columns: 36px 1fr auto; gap: 1rem; padding: 1.4rem 1.2rem; }
    .p-num { font-size: 1.2rem; }
    .p-title { font-size: 1.2rem; }
    .p-desc { display: none; }

    /* skills */
    .skills-grid { grid-template-columns: 1fr 1fr; }
    .skill-item { padding: 1.5rem 1.2rem; }
    .skill-name { font-size: 1.1rem; margin-bottom: 0.7rem; }

    /* drone */
    .drone-visual { display: none; }

    /* contact */
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .cli { padding: 1.2rem 0; }
    .cli-text { font-size: 0.88rem; }

    /* footer */
    footer { flex-direction: column; gap: 0.4rem; text-align: center; padding: 1.5rem; }
  }

  @media (max-width: 400px) {
    .hero-title { font-size: 3rem; }
    .stats { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
